{
  "name": "@lazarv/react-server-example-spa",
  "private": true,
  "description": "@lazarv/react-server SPA example application",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "dev": "react-server ./src/index.ssr.jsx",
    "dev:rsc": "react-server ./src/index.rsc.jsx",
    "build": "react-server build ./src/index.ssr.jsx --outDir .react-server-ssr --edge",
    "build:rsc": "react-server build ./src/index.rsc.jsx --outDir .react-server-rsc --edge",
    "start": "react-server start --outDir .react-server-ssr",
    "start:rsc": "react-server start --outDir .react-server-rsc",
    "bench": "node bench.mjs",
    "bench:build": "node bench.mjs --build"
  },
  "dependencies": {
    "@lazarv/react-server": "workspace:^"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
