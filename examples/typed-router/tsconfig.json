{
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["react/experimental"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/*.js", "**/*.mjs", "node_modules"]
}
