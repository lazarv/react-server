{
  "private": true,
  "keywords": [
    "esm",
    "react",
    "server",
    "ssr"
  ],
  "bugs": {
    "url": "https://github.com/lazarv/react-server/issues"
  },
  "license": "MIT",
  "author": "lazarv",
  "repository": {
    "type": "git",
    "url": "https://github.com/lazarv/react-server.git"
  },
  "type": "module",
  "scripts": {
    "test": "pnpm --filter ./test test",
    "format": "oxfmt . --no-error-on-unmatched-pattern",
    "lint": "oxlint",
    "docs": "pnpm --filter ./docs dev --open",
    "docs-build": "pnpm --filter ./docs build",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@lazarv/create-react-server": "link:packages/create-react-server",
    "@lazarv/react-server": "link:packages/react-server"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@types/node": "^20.12.12",
    "lint-staged": "^15.2.9",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.34.0",
    "pkg-pr-new": "^0.0.20",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.6.3",
    "typescript-plugin-css-modules": "^5.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,ts,tsx,json}": [
      "oxfmt"
    ],
    "*.{js,jsx,mjs,ts,tsx}": [
      "oxlint --fix"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "react-click-away-listener>react": "0.0.0-experimental-561ed529-20260423",
      "react-click-away-listener>react-dom": "0.0.0-experimental-561ed529-20260423",
      "react-router-dom>react": "0.0.0-experimental-561ed529-20260423",
      "react-router-dom>react-dom": "0.0.0-experimental-561ed529-20260423",
      "react-router>react": "0.0.0-experimental-561ed529-20260423",
      "@tanstack/react-router>react": "0.0.0-experimental-561ed529-20260423",
      "@tanstack/react-router>react-dom": "0.0.0-experimental-561ed529-20260423",
      "@tanstack/react-store>react": "0.0.0-experimental-561ed529-20260423",
      "@tanstack/react-store>react-dom": "0.0.0-experimental-561ed529-20260423",
      "use-sync-external-store>react": "0.0.0-experimental-561ed529-20260423",
      "@tanstack/router-devtools>react": "0.0.0-experimental-561ed529-20260423",
      "@tanstack/router-devtools>react-dom": "0.0.0-experimental-561ed529-20260423",
      "@docsearch/react>react": "0.0.0-experimental-561ed529-20260423",
      "@uidotdev/usehooks>react": "0.0.0-experimental-561ed529-20260423",
      "@uidotdev/usehooks>react-dom": "0.0.0-experimental-561ed529-20260423",
      "@vercel/analytics>react": "0.0.0-experimental-561ed529-20260423",
      "@vercel/speed-insights>react": "0.0.0-experimental-561ed529-20260423",
      "vite": "8.0.10",
      "vite-plugin-inspect>vite": "8.0.10",
      "vite-plugin-svgr>vite": "8.0.10",
      "@vitejs/plugin-react>vite": "8.0.10",
      "@vitejs/plugin-react-swc>vite": "8.0.10",
      "supertest>superagent": "9.0.2",
      "browserslist": "4.28.1",
      "caniuse-lite": "1.0.30001761"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@swc/core",
      "@vercel/speed-insights",
      "better-sqlite3",
      "esbuild",
      "playwright-chromium",
      "protobufjs",
      "simple-git-hooks"
    ]
  }
}
